---
// The frontmatter runs at build time. We just define the page title here.
const pageTitle = "allen su";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<main>
			<p>allen su</p>
			<p>
				currently working on
				<a href="/quiet-eval-aware-writeup.pdf">detecting quiet eval-awareness</a>
			</p>
			<p class="blurb">
				previously built ML testing tooling on Apple's Proactive Intelligence
				team that powers Shortcuts and personal intelligence features like app
				suggestions, founded and built
				<a href="https://codedreams.app/">Codedreams</a> (an AI tutor for iOS
				devs), did intracortical BCI research at
				<a href="https://www.braingate.org/">BrainGate</a>, and worked on poker
				&amp; tech at <a href="https://www.rf.team/">RF Labs</a>
			</p>
			<p>georgia tech</p>
			<p>human capital</p>
			<p class="links">
				<a href="https://www.linkedin.com/in/allensu02/">linkedin</a>
				<a href="https://x.com/allenysu">x</a>
				<a href="https://github.com/allensu02">github</a>
				<span>allensu [at] gatech.edu</span>
			</p>
		</main>
	</body>
</html>

<style>
	/*
	 * Full black background.
	 * Setting it on html guarantees the color fills the whole viewport,
	 * even past the body's content box.
	 */
	html {
		background-color: #000000;
		color: #ffffff;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
	}

	body {
		margin: 0;
		min-height: 100vh;
		padding: 2rem;
	}

	main p {
		margin: 0 0 0.25rem;
	}

	/*
	 * All inline links in the content are teal (same as the footer links).
	 * They only underline on hover to keep the page clean.
	 */
	main a {
		color: #5EEAD4;
		text-decoration: none;
	}

	main a:hover {
		text-decoration: underline;
	}

	/*
	 * The "previously" blurb is a full sentence, so we cap its width and
	 * add breathing room above/below to separate it from the short lines.
	 */
	.blurb {
		max-width: 42rem;
		margin: 0.75rem 0 1.25rem;
		line-height: 1.6;
	}

	/*
	 * The links line sits a bit below the three text lines.
	 * Using flex with a gap spaces the items evenly and wraps
	 * them cleanly on narrow screens.
	 */
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1rem;
	}

	.links a {
		color: #5EEAD4;
		text-decoration: none;
	}

	.links a:hover {
		text-decoration: underline;
	}

	.links span {
		color: #ffffff;
	}
</style>
