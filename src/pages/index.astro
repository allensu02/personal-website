---
// This is the "frontmatter" section - it runs on the server at build time
// You can import components, fetch data, or define variables here
const pageTitle = "allen";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<!-- Navigation -->
		<nav>
			<a href="/" class="nav-link active">home</a>
			<a href="/about" class="nav-link">about me</a>
			<a href="/writings" class="nav-link">writings</a>
			<a href="/random" class="nav-link">random</a>
		</nav>

		<!-- Main Content -->
		<main>
			<h1>hi, i'm allen</h1>

			<p>
				i'm 23yo, based in South Bay, but moving to SF soon!
				i just moved back from Taiwan, where I completed 6 months of mandatory military service
			</p>

			<p>
				most recently I founded and built <a href="https://codedreams.app/">Codedreams</a>, an AI tutor for iOS devs
			</p>
			<p>
				before that, I did research with intracortical BCIs at <a href="https://www.braingate.org/">BrainGate</a>
			</p>
			<p>
				and i worked on cool poker & tech stuff at <a href="https://www.rf.team/">RF Labs</a>
			</p>
			<p>
				you can reach me via <a href="https://x.com/allenysu">X</a> or email me at
				allensu [at] gatech.edu
			</p>

			<!-- Social Links -->
			<div class="social-links">
				<a href="https://www.linkedin.com/in/allensu02/" class="social-link">
					<span class="arrow">↗</span> linkedin
				</a>
				
				<a href="https://github.com/allensu02" class="social-link">
					<span class="arrow">↗</span> github
				</a>
			</div>

			<p class="age-line">
				born <span id="live-age" data-live-age>23 yr 8 mo</span> ago in LA, CA 🌴
			</p>
		</main>

		<script>
			const birth = {
				year: 2002,
				month: 9,
				day: 10,
				hour: 9,
				minute: 10,
				second: 0,
			};

			const ageElement = document.querySelector("[data-live-age]");
			const losAngelesFormatter = new Intl.DateTimeFormat("en-US", {
				timeZone: "America/Los_Angeles",
				year: "numeric",
				month: "numeric",
				day: "numeric",
				hour: "numeric",
				minute: "numeric",
				second: "numeric",
				hourCycle: "h23",
			});

			const getLosAngelesParts = (date) => {
				const parts = Object.fromEntries(
					losAngelesFormatter
						.formatToParts(date)
						.filter((part) => part.type !== "literal")
						.map((part) => [part.type, Number(part.value)])
				);

				return {
					year: parts.year,
					month: parts.month,
					day: parts.day,
					hour: parts.hour,
					minute: parts.minute,
					second: parts.second,
				};
			};

			const daysInMonth = (year, month) => new Date(Date.UTC(year, month, 0)).getUTCDate();

			const getAgeParts = () => {
				const now = getLosAngelesParts(new Date());

				let years = now.year - birth.year;
				let months = now.month - birth.month;
				let days = now.day - birth.day;
				let hours = now.hour - birth.hour;
				let minutes = now.minute - birth.minute;
				let seconds = now.second - birth.second;

				if (seconds < 0) {
					seconds += 60;
					minutes -= 1;
				}

				if (minutes < 0) {
					minutes += 60;
					hours -= 1;
				}

				if (hours < 0) {
					hours += 24;
					days -= 1;
				}

				if (days < 0) {
					const previousMonth = now.month === 1 ? 12 : now.month - 1;
					const previousMonthYear = now.month === 1 ? now.year - 1 : now.year;

					days += daysInMonth(previousMonthYear, previousMonth);
					months -= 1;
				}

				if (months < 0) {
					months += 12;
					years -= 1;
				}

				return { years, months, days, hours, minutes, seconds };
			};

			const renderAge = () => {
				if (!ageElement) return;

				const { years, months, days, hours, minutes, seconds } = getAgeParts();

				ageElement.textContent = `${years} yr ${months} mo ${days} day ${hours} hr ${minutes} min ${seconds} sec`;
			};

			renderAge();
			setInterval(renderAge, 1000);
		</script>
	</body>
</html>

<style>
	/*
	 * GLOBAL STYLES
	 * We define CSS variables (custom properties) at the :root level
	 * This makes it easy to change colors across the entire site
	 */
	:root {
		--bg-color: #000000;
		--text-color: #ffffff;
		--link-color: #5EEAD4;        /* Mint/Teal - your choice! */
		--text-muted: #9CA3AF;        /* Gray for subtle text */
	}

	/*
	 * Base styles for the HTML element
	 * We use a system font stack for fast loading and native feel
	 */
	html {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
	}

	/*
	 * Body reset and layout
	 * max-width constrains content for readability (long lines are hard to read)
	 * margin: 0 auto centers the content horizontally
	 */
	body {
		margin: 0;
		padding: 2rem;
		max-width: 650px;
		margin: 0 auto;
		line-height: 1.6;             /* Spacing between lines - improves readability */
	}

	/*
	 * NAVIGATION
	 * display: flex puts items in a row
	 * gap adds space between flex items (cleaner than margins)
	 */
	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		margin-bottom: 3rem;
	}

	.nav-link {
		color: var(--text-muted);
		text-decoration: none;        /* Removes the underline */
		font-size: 0.95rem;
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--text-color);     /* White when hovered or active */
	}

	/*
	 * TYPOGRAPHY
	 * The heading uses a larger font-weight for that bold look
	 */
	h1 {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		letter-spacing: -0.02em;      /* Slightly tighter letter spacing looks modern */
	}

	p {
		margin-bottom: 1rem;
		color: var(--text-color);
	}

	/*
	 * LINKS
	 * Inline links get the mint/teal color
	 */
	a {
		color: var(--link-color);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;   /* Underline on hover gives feedback */
	}

	/*
	 * SOCIAL LINKS SECTION
	 * Another flex container for the bottom links
	 */
	.social-links {
		display: flex;
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.social-link {
		color: var(--link-color);
		font-size: 0.95rem;
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.social-link:hover {
		color: var(--link-color);
		text-decoration: underline;
	}

	.arrow {
		font-size: 0.85rem;
	}

	.age-line {
		color: var(--text-muted);
		font-size: 0.95rem;
		margin-top: 1.25rem;
	}

	#live-age {
		color: var(--text-color);
		font-variant-numeric: tabular-nums;
	}
</style>
