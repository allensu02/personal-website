<style>
	:root {
		--bg-color: #000000;
		--text-color: #ffffff;
		--link-color: #5EEAD4;
		--text-muted: #9CA3AF;
	}

	html {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
	}

	body {
		margin: 0;
		padding: 2rem;
		max-width: 650px;
		margin: 0 auto;
		line-height: 1.6;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		margin-bottom: 3rem;
	}

	.nav-link {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.95rem;
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--text-color);
	}

	h1 {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		letter-spacing: -0.02em;
	}

	p {
		margin-bottom: 1rem;
		color: var(--text-color);
	}

	a {
		color: var(--link-color);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	.back-link {
		display: inline-block;
		margin-top: 2rem;
		color: var(--text-muted);
		font-size: 0.95rem;
	}

	.back-link:hover {
		color: var(--link-color);
		text-decoration: none;
	}
</style>
